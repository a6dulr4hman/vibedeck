# ---- Backend environment (Coolify secrets) ----
# MongoDB hosted on Coolify (or any reachable Mongo). Use the internal service URL.
MONGO_URL=mongodb://mongo:27017
DB_NAME=vibedeck_db

# Clerk (production keys for your domain)
CLERK_SECRET_KEY=sk_live_xxx
CLERK_PUBLISHABLE_KEY=pk_live_xxx
# Comma-separated origins allowed to mint Clerk tokens (your frontend domain[s])
CLERK_AUTHORIZED_PARTIES=https://vibedeck.falak.me

# K2 Think v2 (default Director)
K2_API_KEY=IFM-xxx
K2_BASE_URL=https://api.k2think.ai/v1

# NVIDIA build.nvidia.com (DeepSeek V4 Pro + Nemotron 3 Ultra)
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Emergent universal key (Gemini 3.1 Pro + Claude Sonnet 4.6)
EMERGENT_LLM_KEY=sk-emergent-xxx

# Production hardening
ALLOW_TEST_AUTH=false
CORS_ORIGINS=https://vibedeck.falak.me
