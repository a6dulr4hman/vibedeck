# ---- Frontend build args (CRA bakes these at build time) ----
# Public URL of the backend service
REACT_APP_BACKEND_URL=https://api.vibedeck.falak.me
# Clerk production publishable key (domain-locked to your domain)
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_xxx
# MUST be false in production so real Clerk auth is used
REACT_APP_DEMO_AUTH=false
